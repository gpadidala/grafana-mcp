# grafana-mcp — environment variables
#
# Copy to `.env` and fill in. `.env` is gitignored.
# Authoritative source for env var names: upstream Grafana MCP README.
# CLI-flag-only options (TLS, address, etc.) are translated by docker/entrypoint.sh.

# ─── Grafana connection (mandatory) ─────────────────────────────────────────
GRAFANA_URL=http://host.docker.internal:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# ─── Grafana auth (alternative — deprecated, prefer service account) ────────
# GRAFANA_USERNAME=
# GRAFANA_PASSWORD=

# ─── Multi-org / header forwarding ──────────────────────────────────────────
# Numeric org id, scopes API calls to that organisation.
# GRAFANA_ORG_ID=1
# JSON object of extra headers added to every Grafana request.
# GRAFANA_EXTRA_HEADERS={"X-Caller":"grafana-mcp"}
# Comma-separated header allowlist forwarded from MCP client → Grafana.
# Only honoured for SSE / streamable-http transports.
# GRAFANA_FORWARD_HEADERS=

# ─── Host port overrides (only when default ports are taken) ────────────────
# MCP_HOST_PORT=8000
# GRAFANA_HOST_PORT=3000
# INSPECTOR_HOST_PORT=6274

# ─── Optional Grafana plugins (compose `local-grafana` profile) ─────────────
# Empty by default so Grafana boots even on hosts whose network blocks
# https://grafana.com (corporate TLS inspection, air-gapped envs, etc.).
# Enable per-env when you want extra datasource types in the local stack.
# GF_INSTALL_PLUGINS=grafana-clickhouse-datasource

# ─── MCP transport ──────────────────────────────────────────────────────────
# stdio | sse | streamable-http  (default streamable-http for container use)
MCP_TRANSPORT=streamable-http
MCP_ADDRESS=0.0.0.0:8000
# --base-path / --endpoint-path translate via entrypoint when set.
# MCP_BASE_PATH=
# MCP_ENDPOINT_PATH=/

# ─── Logging ────────────────────────────────────────────────────────────────
MCP_LOG_LEVEL=info
MCP_DEBUG=false

# ─── Safety: disable mutating tools by default ──────────────────────────────
# Production overlay forces this to true; flip to false for local edit flows.
MCP_DISABLE_WRITE=false

# ─── Tool categories ────────────────────────────────────────────────────────
# Comma-separated allowlist. Empty = upstream default set (which OMITS
# admin/clickhouse/cloudwatch/elasticsearch/examples/graphite/influxdb/
# runpanelquery/searchlogs).
#
# When you have all plugins/datasources installed in Grafana, use the FULL
# preset below so the MCP can reach every one of them. See
# config/tools.env.example for narrower presets.
MCP_ENABLED_TOOLS=search,datasource,dashboard,prometheus,loki,alerting,oncall,incidents,sift,navigation,annotations,rendering,pyroscope,asserts,admin,clickhouse,cloudwatch,elasticsearch,examples,graphite,influxdb,runpanelquery,searchlogs

# ─── Metrics ────────────────────────────────────────────────────────────────
MCP_METRICS=true
# Optional separate listener (e.g. :9090). Empty = same listener as MCP_ADDRESS.
# MCP_METRICS_ADDRESS=

# ─── Session reaping ────────────────────────────────────────────────────────
# Idle minutes before a streamable-http session is reaped. 0 disables.
MCP_SESSION_IDLE_TIMEOUT_MINUTES=30

# ─── Loki guardrails ────────────────────────────────────────────────────────
MCP_MAX_LOKI_LOG_LIMIT=100

# ─── OpenTelemetry tracing (optional) ───────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=https://tempo.example:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20...
# OTEL_EXPORTER_OTLP_INSECURE=false

# ─── TLS — client (Grafana side) ────────────────────────────────────────────
# Translated by entrypoint to --tls-cert-file / --tls-key-file / --tls-ca-file.
# MCP_TLS_CERT_FILE=
# MCP_TLS_KEY_FILE=
# MCP_TLS_CA_FILE=
# MCP_TLS_SKIP_VERIFY=false

# ─── TLS — server (streamable-http only) ────────────────────────────────────
# Translated by entrypoint to --server.tls-cert-file / --server.tls-key-file.
# MCP_SERVER_TLS_CERT_FILE=
# MCP_SERVER_TLS_KEY_FILE=

# ─── Corporate network: outbound proxy + CA bundle ──────────────────────────
# When the MCP container reaches Grafana through a corporate forward proxy
# (typical for prod-pointing deploys), set these. Lower-case versions are
# also honoured by Go's net/http.
# HTTP_PROXY=http://corp-proxy.example.com:3128
# HTTPS_PROXY=http://corp-proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,.svc.cluster.local,.example.com
#
# When your corporate firewall does TLS inspection (re-signs certs with an
# internal root CA), choose ONE of these:
#
#   - Quick / insecure (dev only):
#       MCP_TLS_SKIP_VERIFY=true
#
#   - Proper: drop ca.pem under ./certs/ and uncomment in
#     compose/docker-compose.override.yml.example, then:
#       MCP_TLS_CA_FILE=/certs/ca.pem
#     SSL_CERT_FILE additionally trusts the bundle for any non-Grafana
#     outbound (OTel collector, etc.).
# SSL_CERT_FILE=/certs/ca.pem
