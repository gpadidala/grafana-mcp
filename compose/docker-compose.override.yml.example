# Copy to docker-compose.override.yml — this file is gitignored.
# Use it for laptop-specific tweaks: cert mounts, custom ports, mounted .env, etc.
#
# Compose merges override.yml on top of docker-compose.yml automatically when
# both live in the same directory.

services:
  grafana-mcp:
    # Corporate-CA bundle — drop the cert at certs/ca.pem on the host.
    # Required when your corporate firewall does TLS inspection and
    # re-signs upstream certs with an internal CA the container doesn't
    # trust by default. See docs/multi-env.md §"TLS gotchas".
    volumes:
      - ../certs:/certs:ro
    environment:
      # Either skip verification (dev/lab only):
      # MCP_TLS_SKIP_VERIFY: "true"
      # Or trust the corporate CA properly (recommended):
      MCP_TLS_CA_FILE: /certs/ca.pem
      SSL_CERT_FILE: /certs/ca.pem
    # Move the host port if 8000 is taken.
    # ports: !override
    #   - "18000:8000"
