# Copy to docker-compose.override.yml — this file is gitignored.
# Use it for laptop-specific tweaks: cert mounts, custom ports, mounted .env, etc.
#
# Compose merges override.yml on top of docker-compose.yml automatically when
# both live in the same directory.

services:
  grafana-mcp:
    # Mount client TLS material so MCP can talk to a TLS-fronted Grafana.
    volumes:
      - ./certs:/certs:ro
    environment:
      MCP_TLS_CERT_FILE: /certs/client.crt
      MCP_TLS_KEY_FILE: /certs/client.key
      MCP_TLS_CA_FILE: /certs/ca.crt
    # Move the host port if 8000 is taken.
    ports: !override
      - "18000:8000"
