{
  "title": "grafana-mcp — Tools / Operations",
  "uid": "grafana-mcp-tools",
  "tags": ["grafana-mcp", "tools"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" } },
      { "name": "namespace", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{job=~\".*grafana-mcp.*\"}, namespace)",
        "current": { "text": "grafana-mcp", "value": "grafana-mcp" } },
      { "name": "method", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}, mcp_method_name)",
        "multi": true, "includeAll": true,
        "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    { "id": 1, "type": "stat", "title": "Selected methods — RPS",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[5m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps" } } },

    { "id": 2, "type": "stat", "title": "Selected methods — total calls (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [ { "expr": "sum(increase(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[$__range]))", "refId": "A" } ] },

    { "id": 3, "type": "stat", "title": "Avg latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "sum(rate(mcp_server_operation_duration_seconds_sum{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[5m])) / sum(rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[5m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s" } } },

    { "id": 4, "type": "stat", "title": "Distinct methods",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "count(count by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m]) > 0))", "refId": "A" } ] },

    { "id": 10, "type": "timeseries", "title": "Calls/sec by method",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "targets": [ { "expr": "sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[1m]))", "legendFormat": "{{mcp_method_name}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } } },

    { "id": 20, "type": "heatmap", "title": "Latency heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "targets": [ { "expr": "sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[1m]))", "format": "heatmap", "refId": "A" } ] },

    { "id": 21, "type": "timeseries", "title": "p95 by method",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\", mcp_method_name=~\"$method\"}[5m])))", "legendFormat": "{{mcp_method_name}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s" } } },

    { "id": 30, "type": "table", "title": "Per-method latency breakdown",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p50", "refId": "A", "format": "table", "instant": true },
        { "expr": "histogram_quantile(0.95, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p95", "refId": "B", "format": "table", "instant": true },
        { "expr": "histogram_quantile(0.99, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p99", "refId": "C", "format": "table", "instant": true },
        { "expr": "sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m]))", "legendFormat": "rps", "refId": "D", "format": "table", "instant": true }
      ],
      "transformations": [ { "id": "merge" } ] }
  ]
}
