{
  "title": "grafana-mcp — Sessions",
  "uid": "grafana-mcp-sessions",
  "tags": ["grafana-mcp", "sessions"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" } },
      { "name": "namespace", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(mcp_sessions_active, namespace)",
        "current": { "text": "grafana-mcp", "value": "grafana-mcp" } }
    ]
  },
  "panels": [
    { "id": 1, "type": "stat", "title": "Active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=\"$namespace\"})", "refId": "A" } ] },

    { "id": 2, "type": "stat", "title": "Sessions per pod (avg)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [ { "expr": "avg by () (mcp_sessions_active{namespace=\"$namespace\"})", "refId": "A" } ] },

    { "id": 3, "type": "stat", "title": "Sessions ended (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "sum(increase(mcp_server_session_duration_seconds_count{namespace=\"$namespace\"}[$__range]))", "refId": "A" } ] },

    { "id": 4, "type": "stat", "title": "p95 session duration",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_session_duration_seconds_bucket{namespace=\"$namespace\"}[1h])))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s" } } },

    { "id": 10, "type": "timeseries", "title": "Active sessions over time (per pod)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [ { "expr": "mcp_sessions_active{namespace=\"$namespace\"}", "legendFormat": "{{pod}}", "refId": "A" } ] },

    { "id": 11, "type": "timeseries", "title": "Session churn (close rate)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [ { "expr": "sum(rate(mcp_server_session_duration_seconds_count{namespace=\"$namespace\"}[5m]))", "legendFormat": "ended/sec", "refId": "A" } ] },

    { "id": 20, "type": "heatmap", "title": "Session-duration heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "targets": [ { "expr": "sum by (le) (rate(mcp_server_session_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))", "format": "heatmap", "refId": "A" } ] },

    { "id": 30, "type": "timeseries", "title": "Grafana-client cache hit rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [ { "expr": "sum(rate(mcp_client_cache_hits_total{namespace=\"$namespace\"}[5m])) / sum(rate(mcp_client_cache_lookups_total{namespace=\"$namespace\"}[5m]))", "legendFormat": "hit ratio", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } } },

    { "id": 31, "type": "stat", "title": "Cached clients (current)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [ { "expr": "sum(mcp_client_cache_size{namespace=\"$namespace\"})", "refId": "A" } ] }
  ]
}
