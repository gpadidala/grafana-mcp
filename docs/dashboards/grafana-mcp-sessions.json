{
  "title": "grafana-mcp — Sessions",
  "uid": "grafana-mcp-sessions",
  "tags": ["grafana-mcp", "sessions"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [
    { "name": "Restarts", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "enable": true, "iconColor": "red",
      "expr": "changes(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]) > 0", "titleFormat": "Pod restart", "tagKeys": "pod" }
  ] },
  "templating": { "list": [
    { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "prometheus" } },
    { "name": "namespace", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "query": "label_values(mcp_sessions_active, namespace)", "current": { "text": "grafana-mcp", "value": "grafana-mcp" } }
  ] },
  "links": [
    { "title": "Overview", "type": "link", "icon": "external link", "url": "/d/grafana-mcp-overview", "targetBlank": false },
    { "title": "Tools",    "type": "link", "icon": "external link", "url": "/d/grafana-mcp-tools",    "targetBlank": false },
    { "title": "Runtime",  "type": "link", "icon": "external link", "url": "/d/grafana-mcp-runtime",  "targetBlank": false }
  ],
  "panels": [
    { "type": "row", "id": 100, "title": "Now", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    { "id": 1, "type": "stat", "title": "Active sessions",
      "description": "Concurrent open MCP streamable-http sessions across all pods.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=~\"$namespace\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 } ] } } } },

    { "id": 2, "type": "stat", "title": "Avg sessions per pod",
      "description": "Helps spot single-pod hot-spots. Even distribution is usually a sign of healthy load balancing at the ingress.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [ { "expr": "avg(mcp_sessions_active{namespace=~\"$namespace\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } } },

    { "id": 3, "type": "stat", "title": "Sessions ended in range",
      "description": "Total sessions that closed during the dashboard time range. Sample count of mcp_server_session_duration_seconds.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [ { "expr": "sum(increase(mcp_server_session_duration_seconds_count{namespace=~\"$namespace\"}[$__range]))", "refId": "A" } ],
      "options": { "graphMode": "none", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } } },

    { "id": 4, "type": "stat", "title": "p95 session duration",
      "description": "95th percentile session lifetime. Idle sessions are reaped after MCP_SESSION_IDLE_TIMEOUT_MINUTES — long tails imply long-running clients.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_session_duration_seconds_bucket{namespace=~\"$namespace\"}[1h])))", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 } } },

    { "type": "row", "id": 200, "title": "Concurrency", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 } },

    { "id": 10, "type": "timeseries", "title": "Active sessions per pod",
      "description": "Each line is one pod. A single line dominating the others suggests sticky-session behaviour or an LB issue.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "targets": [ { "expr": "mcp_sessions_active{namespace=~\"$namespace\"}", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 1.5, "fillOpacity": 10 } } } },

    { "id": 11, "type": "timeseries", "title": "Session churn (close rate)",
      "description": "Sessions ending per second. High churn with low active count means short-lived clients (good); high churn with rising active count means a cycling failure.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "targets": [ { "expr": "sum(rate(mcp_server_session_duration_seconds_count{namespace=~\"$namespace\"}[5m]))", "legendFormat": "ended/sec", "refId": "A" } ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2, "custom": { "lineWidth": 2, "fillOpacity": 25 } } } },

    { "type": "row", "id": 300, "title": "Lifetime distribution", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },

    { "id": 20, "type": "heatmap", "title": "Session-duration heatmap",
      "description": "Density of session lifetimes. Multiple bands → bimodal client behaviour (e.g. quick probes + long-running notebooks).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
      "targets": [ { "expr": "sum by (le) (rate(mcp_server_session_duration_seconds_bucket{namespace=~\"$namespace\"}[5m]))", "format": "heatmap", "refId": "A", "legendFormat": "{{le}}" } ],
      "options": { "calculate": false, "yAxis": { "unit": "s" }, "color": { "mode": "scheme", "scheme": "Oranges", "reverse": false }, "tooltip": { "show": true, "yHistogram": true } } },

    { "type": "row", "id": 400, "title": "Grafana-client cache", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 } },

    { "id": 30, "type": "timeseries", "title": "Cache hit ratio",
      "description": "MCP caches the inner Grafana HTTP client across calls. Hit rate near 1.0 means most calls reuse an existing client; sustained low hit rate suggests session churn or per-call header overrides minting new clients.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "targets": [ { "expr": "sum(rate(mcp_client_cache_hits_total{namespace=~\"$namespace\"}[5m])) / clamp_min(sum(rate(mcp_client_cache_lookups_total{namespace=~\"$namespace\"}[5m])), 1)", "legendFormat": "hit ratio", "refId": "A" } ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "decimals": 3,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 } ] },
        "custom": { "lineWidth": 2, "fillOpacity": 25, "thresholdsStyle": { "mode": "dashed" } } } } },

    { "id": 31, "type": "stat", "title": "Cached clients (current)",
      "description": "Distinct Grafana clients currently in cache. Grows with the number of distinct token / org / header combinations seen.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "targets": [ { "expr": "sum(mcp_client_cache_size{namespace=~\"$namespace\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } } }
  ]
}
