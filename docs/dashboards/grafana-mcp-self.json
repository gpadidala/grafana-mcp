{
  "title": "grafana-mcp — self monitoring",
  "uid": "grafana-mcp-self",
  "tags": ["grafana-mcp", "self-monitoring"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{job=~\".*grafana-mcp.*\"}, namespace)",
        "current": { "text": "grafana-mcp", "value": "grafana-mcp" }
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Pods up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(up{job=~\".*grafana-mcp.*\", namespace=\"$namespace\"})", "refId": "A" } ]
    },
    {
      "id": 2, "type": "stat", "title": "p95 op latency (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [ {
        "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
        "refId": "A"
      } ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3, "type": "stat", "title": "Error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [ {
        "expr": "sum(rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\", status=\"error\"}[5m])) / sum(rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m]))",
        "refId": "A"
      } ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 4, "type": "stat", "title": "Active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [ { "expr": "sum(mcp_server_active_sessions{namespace=\"$namespace\"})", "refId": "A" } ]
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Operation latency by tool — p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [ {
        "expr": "topk(10, histogram_quantile(0.95, sum by (le, operation) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))))",
        "legendFormat": "{{operation}}", "refId": "A"
      } ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Calls per second by tool",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [ {
        "expr": "topk(10, sum by (operation) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m])))",
        "legendFormat": "{{operation}}", "refId": "A"
      } ]
    },
    {
      "id": 20, "type": "timeseries",
      "title": "Memory working set / limit",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "targets": [ {
        "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", container=\"mcp\"} / container_spec_memory_limit_bytes{namespace=\"$namespace\", container=\"mcp\"}",
        "legendFormat": "{{pod}}", "refId": "A"
      } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }
    },
    {
      "id": 21, "type": "timeseries",
      "title": "Pod restart count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "targets": [ {
        "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h])",
        "legendFormat": "{{pod}}", "refId": "A"
      } ]
    }
  ]
}
