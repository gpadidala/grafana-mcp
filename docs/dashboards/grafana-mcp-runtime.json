{
  "title": "grafana-mcp — Runtime / Resources",
  "uid": "grafana-mcp-runtime",
  "tags": ["grafana-mcp", "runtime", "resources"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [
    { "name": "Restarts", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "enable": true, "iconColor": "red",
      "expr": "changes(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]) > 0", "titleFormat": "Pod restart", "tagKeys": "pod" }
  ] },
  "templating": { "list": [
    { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "prometheus" } },
    { "name": "namespace", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "query": "label_values(go_goroutines{job=~\".*grafana-mcp.*\"}, namespace)", "current": { "text": "grafana-mcp", "value": "grafana-mcp" } },
    { "name": "pod", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "query": "label_values(go_goroutines{namespace=~\"$namespace\"}, pod)", "multi": true, "includeAll": true,
      "current": { "text": "All", "value": "$__all" } }
  ] },
  "links": [
    { "title": "Overview", "type": "link", "icon": "external link", "url": "/d/grafana-mcp-overview", "targetBlank": false },
    { "title": "Sessions", "type": "link", "icon": "external link", "url": "/d/grafana-mcp-sessions", "targetBlank": false }
  ],
  "panels": [
    { "type": "row", "id": 100, "title": "Process at a glance", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    { "id": 1, "type": "stat", "title": "Goroutines",
      "description": "Live goroutine count. Sustained growth without traffic correlation indicates a leak.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [ { "expr": "sum(go_goroutines{namespace=~\"$namespace\", pod=~\"$pod\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 } ] } } } },

    { "id": 2, "type": "stat", "title": "OS threads",
      "description": "Underlying OS threads — should be small and stable.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [ { "expr": "sum(go_threads{namespace=~\"$namespace\", pod=~\"$pod\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } } },

    { "id": 3, "type": "stat", "title": "Heap in use",
      "description": "Live heap memory across the selected pods. Compare against the container memory limit on the Overview dashboard.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [ { "expr": "sum(go_memstats_heap_inuse_bytes{namespace=~\"$namespace\", pod=~\"$pod\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } } },

    { "id": 4, "type": "stat", "title": "Open FDs / max",
      "description": "Open file descriptors out of the process limit. Approaching `process_max_fds` is a runaway-leak signal.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "sum(process_open_fds{namespace=~\"$namespace\", pod=~\"$pod\"})", "refId": "A", "legendFormat": "open" },
        { "expr": "sum(process_max_fds{namespace=~\"$namespace\", pod=~\"$pod\"})",  "refId": "B", "legendFormat": "max" }
      ],
      "options": { "graphMode": "none", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } } },

    { "type": "row", "id": 200, "title": "Concurrency", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 } },

    { "id": 10, "type": "timeseries", "title": "Goroutines per pod",
      "description": "One line per pod. Diverging pod implies imbalanced load or a stuck handler.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "targets": [ { "expr": "go_goroutines{namespace=~\"$namespace\", pod=~\"$pod\"}", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 1.5, "fillOpacity": 5 } } } },

    { "id": 11, "type": "timeseries", "title": "GC pause p95",
      "description": "Stop-the-world garbage-collection pause at p95. Sustained values >100ms suggest heap pressure — bump GOMEMLIMIT or memory request.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "targets": [ { "expr": "go_gc_duration_seconds{namespace=~\"$namespace\", pod=~\"$pod\", quantile=\"0.95\"}", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 4,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 } ] },
        "custom": { "thresholdsStyle": { "mode": "dashed" } } } } },

    { "type": "row", "id": 300, "title": "Memory", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },

    { "id": 20, "type": "timeseries", "title": "Heap detail (alloc / inuse / sys / next_gc)",
      "description": "alloc = currently live; inuse = mapped but possibly retained for re-use; sys = total reserved from the OS; next_gc = trigger threshold for the next collection.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "targets": [
        { "expr": "sum(go_memstats_heap_alloc_bytes{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "heap alloc", "refId": "A" },
        { "expr": "sum(go_memstats_heap_inuse_bytes{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "heap inuse", "refId": "B" },
        { "expr": "sum(go_memstats_heap_sys_bytes{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "heap sys",   "refId": "C" },
        { "expr": "sum(go_memstats_next_gc_bytes{namespace=~\"$namespace\", pod=~\"$pod\"})",  "legendFormat": "next gc",    "refId": "D" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2, "custom": { "lineWidth": 1.5 } } } },

    { "id": 21, "type": "timeseries", "title": "CPU usage",
      "description": "Container CPU rate per pod. Compare against the deployment's CPU request/limit.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "targets": [ { "expr": "rate(process_cpu_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\"}[1m])", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3, "custom": { "lineWidth": 1.5, "fillOpacity": 10 } } } },

    { "type": "row", "id": 400, "title": "I/O", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 } },

    { "id": 30, "type": "timeseries", "title": "Network bytes (rx / tx)",
      "description": "Bytes received and transmitted by the process. Sudden multi-fold rises usually correlate with a chatty MCP client or a wide PromQL/LogQL query.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "targets": [
        { "expr": "rate(process_network_receive_bytes_total{namespace=~\"$namespace\", pod=~\"$pod\"}[1m])",  "legendFormat": "rx {{pod}}", "refId": "A" },
        { "expr": "rate(process_network_transmit_bytes_total{namespace=~\"$namespace\", pod=~\"$pod\"}[1m])", "legendFormat": "tx {{pod}}", "refId": "B" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 2, "custom": { "lineWidth": 1.5 } } } },

    { "id": 31, "type": "timeseries", "title": "FDs (open / max)",
      "description": "File descriptors. Open should stay well below max; an upward trend without traffic correlation indicates a connection leak.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "targets": [
        { "expr": "process_open_fds{namespace=~\"$namespace\", pod=~\"$pod\"}", "legendFormat": "open {{pod}}", "refId": "A" },
        { "expr": "process_max_fds{namespace=~\"$namespace\", pod=~\"$pod\"}",  "legendFormat": "max {{pod}}",  "refId": "B" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 1.5 } } } }
  ]
}
