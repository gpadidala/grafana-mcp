{
  "title": "grafana-mcp — Overview / SLO",
  "uid": "grafana-mcp-overview",
  "tags": ["grafana-mcp", "slo", "overview"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s","30s","1m","5m","15m","1h"] },
  "annotations": {
    "list": [
      {
        "name": "Restarts",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "iconColor": "red",
        "expr": "changes(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]) > 0",
        "titleFormat": "Pod restart",
        "tagKeys": "pod"
      },
      {
        "name": "Deploys",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "iconColor": "blue",
        "expr": "changes(kube_deployment_status_observed_generation{namespace=~\"$namespace\"}[5m]) > 0",
        "titleFormat": "Deploy",
        "tagKeys": "deployment"
      }
    ]
  },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" } },
      { "name": "namespace", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{job=~\".*grafana-mcp.*\"}, namespace)",
        "current": { "text": "grafana-mcp", "value": "grafana-mcp" } }
    ]
  },
  "links": [
    { "title": "Tools", "type": "link", "icon": "external link",
      "url": "/d/grafana-mcp-tools",        "targetBlank": false },
    { "title": "Sessions", "type": "link", "icon": "external link",
      "url": "/d/grafana-mcp-sessions",     "targetBlank": false },
    { "title": "Errors", "type": "link", "icon": "external link",
      "url": "/d/grafana-mcp-errors",       "targetBlank": false },
    { "title": "Runtime", "type": "link", "icon": "external link",
      "url": "/d/grafana-mcp-runtime",      "targetBlank": false },
    { "title": "SLO", "type": "link", "icon": "external link",
      "url": "/d/grafana-mcp-slo",          "targetBlank": false }
  ],
  "panels": [
    { "type": "row", "id": 100, "title": "Headline", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    { "id": 1, "type": "stat", "title": "Pods up",
      "description": "Count of MCP pods responding to /metrics scrape. Drops below desired replicas → fires GrafanaMcpDown.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "targets": [ { "expr": "sum(up{job=~\".*grafana-mcp.*\", namespace=~\"$namespace\"})", "refId": "A", "legendFormat": "pods" } ],
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "value_and_name", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 } ] },
        "links": [{ "title": "Drill into Errors", "url": "/d/grafana-mcp-errors?var-namespace=${namespace}" }]
      } } },

    { "id": 2, "type": "stat", "title": "Active sessions",
      "description": "Concurrent MCP sessions across all pods. Capacity sizing pivot — alerts at >200.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=~\"$namespace\"})", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 } ] },
        "links": [{ "title": "Drill into Sessions", "url": "/d/grafana-mcp-sessions?var-namespace=${namespace}" }]
      } } },

    { "id": 3, "type": "stat", "title": "RPS (5m)",
      "description": "Total MCP method invocations per second over the last 5 minutes. Sum across all methods and pods.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "targets": [ { "expr": "sum(rate(mcp_server_operation_duration_seconds_count{namespace=~\"$namespace\"}[5m]))", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "reqps", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
      } } },

    { "id": 4, "type": "stat", "title": "p95 latency (5m)",
      "description": "95th-percentile MCP operation duration over 5m. Crosses 5s ⇒ GrafanaMcpHighOperationLatencyP95 fires.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "s", "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] },
        "links": [{ "title": "Drill into Tools", "url": "/d/grafana-mcp-tools?var-namespace=${namespace}" }]
      } } },

    { "id": 5, "type": "stat", "title": "p99 latency (5m)",
      "description": "99th-percentile MCP operation duration. Crosses 15s ⇒ GrafanaMcpHighOperationLatencyP99 (critical/page).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "targets": [ { "expr": "histogram_quantile(0.99, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "s", "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 } ] }
      } } },

    { "id": 6, "type": "stat", "title": "5xx rate %",
      "description": "Server-error rate measured at the HTTP boundary (the MCP-specific operation metric has no status label). Crosses 5% ⇒ GrafanaMcpHigh5xxRate.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "targets": [ { "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\"}[5m])), 1)", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "percent", "decimals": 2, "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] },
        "links": [{ "title": "Drill into Errors", "url": "/d/grafana-mcp-errors?var-namespace=${namespace}" }]
      } } },

    { "type": "row", "id": 200, "title": "Traffic", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 } },

    { "id": 10, "type": "timeseries", "title": "Request rate by method",
      "description": "Per-method calls/sec, stacked. Hot tools dominate the stack; sudden spikes often correlate with a misbehaving MCP client.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "targets": [ { "expr": "sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=~\"$namespace\"}[1m]))", "legendFormat": "{{mcp_method_name}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean","lastNotNull","max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 25, "lineWidth": 1 } } } },

    { "id": 11, "type": "timeseries", "title": "Latency p50 / p95 / p99",
      "description": "Three quantiles together — divergence between p95 and p99 means tail-latency outliers, not a global slowdown.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","lastNotNull","max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] },
        "custom": { "thresholdsStyle": { "mode": "dashed" }, "lineWidth": 2 } } } },

    { "type": "row", "id": 300, "title": "Concurrency & saturation", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },

    { "id": 20, "type": "timeseries", "title": "Active sessions over time",
      "description": "Concurrent MCP streamable-http sessions. Reaped after MCP_SESSION_IDLE_TIMEOUT_MINUTES of inactivity.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=~\"$namespace\"})", "legendFormat": "active", "refId": "A" } ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 25 } } } },

    { "id": 21, "type": "timeseries", "title": "Memory: working set / limit",
      "description": "Heap working-set as fraction of the container memory limit. Crosses 85% ⇒ GrafanaMcpMemoryPressure. Requires kube-state-metrics + cAdvisor (K8s only).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [ { "expr": "container_memory_working_set_bytes{namespace=~\"$namespace\", container=\"mcp\"} / on(namespace,pod) container_spec_memory_limit_bytes{namespace=~\"$namespace\", container=\"mcp\"}", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 } ] },
        "custom": { "thresholdsStyle": { "mode": "line" }, "lineWidth": 2, "fillOpacity": 10 } } } },

    { "type": "row", "id": 400, "title": "Top movers", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 } },

    { "id": 30, "type": "table", "title": "Top 10 methods by call rate",
      "description": "Hottest tools right now. Click a row to drill into the Tools dashboard for that method.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "targets": [ { "expr": "topk(10, sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=~\"$namespace\"}[5m])))", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2,
        "custom": { "align": "auto", "displayMode": "color-background-solid" },
        "links": [{ "title": "Drill into method", "url": "/d/grafana-mcp-tools?var-namespace=${namespace}&var-method=${__data.fields.mcp_method_name}" }]
      },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [ { "id": "custom.hidden", "value": true } ] }
        ] } },

    { "id": 31, "type": "table", "title": "Top 10 slowest methods (p95)",
      "description": "Methods most likely to feel slow to clients. Pair with Top by call rate to spot quiet-but-slow methods.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "targets": [ { "expr": "topk(10, histogram_quantile(0.95, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=~\"$namespace\"}[5m]))))", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3,
        "custom": { "align": "auto", "displayMode": "color-background-solid" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] },
        "links": [{ "title": "Drill into method", "url": "/d/grafana-mcp-tools?var-namespace=${namespace}&var-method=${__data.fields.mcp_method_name}" }]
      },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [ { "id": "custom.hidden", "value": true } ] }
        ] } }
  ]
}
