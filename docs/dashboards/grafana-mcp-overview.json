{
  "title": "grafana-mcp — Overview / SLO",
  "uid": "grafana-mcp-overview",
  "tags": ["grafana-mcp", "slo", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" } },
      { "name": "namespace", "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{job=~\".*grafana-mcp.*\"}, namespace)",
        "current": { "text": "grafana-mcp", "value": "grafana-mcp" } }
    ]
  },
  "panels": [
    { "id": 1, "type": "stat", "title": "Pods up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(up{job=~\".*grafana-mcp.*\", namespace=\"$namespace\"})", "refId": "A" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 } ] } } } },

    { "id": 2, "type": "stat", "title": "Active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=\"$namespace\"})", "refId": "A" } ] },

    { "id": 3, "type": "stat", "title": "RPS (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [ { "expr": "sum(rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps" } } },

    { "id": 4, "type": "stat", "title": "p95 latency (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] } } } },

    { "id": 5, "type": "stat", "title": "p99 latency (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [ { "expr": "histogram_quantile(0.99, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 } ] } } } },

    { "id": 6, "type": "stat", "title": "5xx rate %",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [ { "expr": "100 * sum(rate(http_server_request_duration_seconds_count{namespace=\"$namespace\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{namespace=\"$namespace\"}[5m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } } },

    { "id": 10, "type": "timeseries", "title": "Request rate by method",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [ { "expr": "sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[1m]))", "legendFormat": "{{mcp_method_name}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } } },

    { "id": 11, "type": "timeseries", "title": "p50 / p95 / p99 latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } } },

    { "id": 20, "type": "timeseries", "title": "Active sessions over time",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "targets": [ { "expr": "sum(mcp_sessions_active{namespace=\"$namespace\"})", "legendFormat": "active", "refId": "A" } ] },

    { "id": 21, "type": "timeseries", "title": "Memory: working set / limit",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "targets": [ { "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", container=\"mcp\"} / container_spec_memory_limit_bytes{namespace=\"$namespace\", container=\"mcp\"}", "legendFormat": "{{pod}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 } ] } } } },

    { "id": 30, "type": "table", "title": "Top 10 methods by call rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [ { "expr": "topk(10, sum by (mcp_method_name) (rate(mcp_server_operation_duration_seconds_count{namespace=\"$namespace\"}[5m])))", "format": "table", "instant": true, "refId": "A" } ] },

    { "id": 31, "type": "table", "title": "Top 10 slowest methods (p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [ { "expr": "topk(10, histogram_quantile(0.95, sum by (le, mcp_method_name) (rate(mcp_server_operation_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))))", "format": "table", "instant": true, "refId": "A" } ] }
  ]
}
