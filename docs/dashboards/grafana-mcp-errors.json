{
  "title": "grafana-mcp — Errors",
  "uid": "grafana-mcp-errors",
  "tags": ["grafana-mcp", "errors"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [
    { "name": "Restarts", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "enable": true, "iconColor": "red",
      "expr": "changes(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]) > 0", "titleFormat": "Pod restart", "tagKeys": "pod" }
  ] },
  "templating": { "list": [
    { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "prometheus" } },
    { "name": "namespace", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "query": "label_values(http_server_request_duration_seconds_count{job=~\".*grafana-mcp.*\"}, namespace)",
      "current": { "text": "grafana-mcp", "value": "grafana-mcp" } }
  ] },
  "links": [
    { "title": "Overview", "type": "link", "icon": "external link", "url": "/d/grafana-mcp-overview", "targetBlank": false },
    { "title": "Tools",    "type": "link", "icon": "external link", "url": "/d/grafana-mcp-tools",    "targetBlank": false },
    { "title": "Runbook",  "type": "link", "icon": "doc",
      "url": "https://github.com/gpadidala/grafana-mcp/blob/main/docs/runbook.md#errors", "targetBlank": true }
  ],
  "panels": [
    { "type": "row", "id": 100, "title": "Headline", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    { "id": 1, "type": "stat", "title": "5xx rate %",
      "description": "Server-error rate at the HTTP boundary over 5m. Crosses 5% ⇒ GrafanaMcpHigh5xxRate.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [ { "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\"}[5m])), 1)", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } } },

    { "id": 2, "type": "stat", "title": "4xx rate %",
      "description": "Client-error rate. Mostly informational — high 4xx often means a misconfigured MCP client; persistent spikes warrant investigation.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [ { "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"4..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\"}[5m])), 1)", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0 } } },

    { "id": 3, "type": "stat", "title": "5xx in range",
      "description": "Total 5xx responses during the dashboard time range — useful for incident reports.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [ { "expr": "sum(increase(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"5..\"}[$__range]))", "refId": "A" } ],
      "options": { "graphMode": "none", "colorMode": "value", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 100 } ] } } } },

    { "id": 4, "type": "stat", "title": "Restarts (1h)",
      "description": "Pod restart count over the last hour. Anything >0 should be investigated. (Requires kube-state-metrics — K8s only.)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [ { "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h]))", "refId": "A" } ],
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 } ] } } } },

    { "type": "row", "id": 200, "title": "Status-code breakdown", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 } },

    { "id": 10, "type": "timeseries", "title": "HTTP responses by status code",
      "description": "Stacked status codes. Even a small slice of red (5xx) is worth investigating; large swings in 4xx usually map to client churn.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "targets": [ { "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\"}[1m]))", "legendFormat": "{{http_response_status_code}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum","lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30, "lineWidth": 1 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^2.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "^4.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byRegexp", "options": "^5.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ] } },

    { "id": 11, "type": "timeseries", "title": "5xx rate over time",
      "description": "Server-error rate. Crosses the dashed line ⇒ alert. Persistent low-level 5xx is usually upstream Grafana auth or rate-limit pressure.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "targets": [ { "expr": "sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"5..\"}[1m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\"}[1m])), 1)", "legendFormat": "5xx rate", "refId": "A" } ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 4, "min": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] },
        "custom": { "thresholdsStyle": { "mode": "dashed" }, "lineWidth": 2, "fillOpacity": 20 } } } },

    { "type": "row", "id": 300, "title": "Upstream Grafana", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },

    { "id": 20, "type": "timeseries", "title": "Pod restarts (15m increase)",
      "description": "Pod-level restarts on a sliding 15m window. Vertical bars correspond to restart events; persistent steps mean a crash loop. (K8s only.)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [ { "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[15m])", "legendFormat": "{{pod}}", "refId": "A" } ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum","lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 2 } } } },

    { "id": 21, "type": "timeseries", "title": "Upstream Grafana p95 (MCP → Grafana)",
      "description": "Outbound HTTP p95 from MCP to upstream Grafana. When this rises and MCP-level p95 follows, the bottleneck is Grafana, not MCP. Crosses 5s ⇒ GrafanaMcpUpstreamGrafanaSlow.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))", "legendFormat": "p95 outbound", "refId": "A" } ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] },
        "custom": { "thresholdsStyle": { "mode": "dashed" }, "lineWidth": 2, "fillOpacity": 20 } } } },

    { "type": "row", "id": 400, "title": "Top failing endpoints", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 } },

    { "id": 30, "type": "table", "title": "Top error endpoints",
      "description": "Endpoints currently producing 4xx or 5xx, ranked by rate. Empty in a healthy stack — that's the desired state.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 26 },
      "targets": [ { "expr": "topk(10, sum by (http_request_method, http_response_status_code, server_address) (rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", http_response_status_code=~\"[45]..\"}[5m])))", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 3, "custom": { "align": "auto", "displayMode": "color-background-solid" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ] } }
  ]
}
