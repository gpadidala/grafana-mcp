# Tool-category presets — append the chosen line to your .env.
#
# The compose default and prod ConfigMap both ship the FULL upstream surface
# (every datasource type, every plugin category). Read-only safety is
# enforced by MCP_DISABLE_WRITE, not by removing tools.
#
# Use the presets below only when you want to narrow the surface.
#
# ─── Full surface — default in compose and base ConfigMap ─────────────────
# MCP_ENABLED_TOOLS=search,datasource,dashboard,prometheus,loki,alerting,oncall,incidents,sift,navigation,annotations,rendering,pyroscope,asserts,admin,clickhouse,cloudwatch,elasticsearch,examples,graphite,influxdb,runpanelquery,searchlogs
#
# ─── Read-only observability (no admin, no writes) ────────────────────────
# MCP_ENABLED_TOOLS=search,datasource,dashboard,prometheus,loki,alerting,annotations,oncall,incidents,sift,navigation,pyroscope,asserts
# MCP_DISABLE_WRITE=true
#
# ─── Read-only EVERY datasource (with auditing of admin) ──────────────────
# MCP_ENABLED_TOOLS=search,datasource,dashboard,prometheus,loki,alerting,annotations,oncall,incidents,sift,navigation,pyroscope,asserts,clickhouse,cloudwatch,elasticsearch,graphite,influxdb,runpanelquery,searchlogs,admin
# MCP_DISABLE_WRITE=true
#
# ─── Minimal Prometheus-only ──────────────────────────────────────────────
# MCP_ENABLED_TOOLS=search,datasource,prometheus
#
# ─── Minimal logs-only (Loki + ClickHouse + Elasticsearch) ────────────────
# MCP_ENABLED_TOOLS=search,datasource,loki,clickhouse,elasticsearch,searchlogs
#
# ─── Audit / governance (admin enabled, writes off) ───────────────────────
# MCP_ENABLED_TOOLS=search,datasource,dashboard,admin
# MCP_DISABLE_WRITE=true

# Per-category RBAC, when enabled, requires the listed Grafana permissions
# on the service-account role. See docs/api-reference.md for the matrix.
